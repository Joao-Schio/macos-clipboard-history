use std::error::Error;

use clipboard_history::{Writer, clipboard_manager::{ClipboardManager, ClipboardRequest}, content_manager::ContentManager, history::{HistoryManager, ManagerRequest}};


async fn setup_history() -> Writer<ManagerRequest> {
    let (w, r) = tokio::sync::mpsc::channel(30);
    let mut history = HistoryManager::new(r);
    tokio::spawn(async move {
        history.start().await
    });
    w
}

async fn setup_clipboard() -> Writer<ClipboardRequest> {
    let (w, r) = tokio::sync::mpsc::channel(30);
    let mut clipboard = ClipboardManager::new(r);
    tokio::spawn(async move {
        clipboard.start().await
    });
    w
}

async fn setup_content(clip : Writer<ClipboardRequest>, hist : Writer<ManagerRequest>) {
    let mut cont = ContentManager::new(clip, hist);
    tokio::spawn(async move {
        cont.start().await
    });
}


#[tokio::main]
async fn main() -> Result<(), Box<dyn Error + Send + Sync>>{
    let history = setup_history().await;
    let clipboard_manager = setup_clipboard().await;
    setup_content(clipboard_manager.clone(), history.clone()).await;
    tokio::time::sleep(tokio::time::Duration::from_secs(20)).await;

    let (tx, tr) = tokio::sync::oneshot::channel();
    let _ = history.send(
        ManagerRequest::Retrieve { response_channel:  tx}
    ).await;

    let vec = tr.await?;
    for i in vec {
        println!("{}", i);
    }
    Ok(())
}