{
    "build": {
        "distDir": "dist",
        "devPath": "dist",
        "withGlobalTauri": true
    },
    "package": {
        "productName": "Clipboard History",
        "version": "0.1.0"
    },
    "tauri": {
        "allowlist": {
            "all": true
        },
        "systemTray": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": true
        },
        "bundle": {
            "active": true,
            "identifier": "dev.joao.clipboard-history",
            "icon": []
        },
        "security": {
            "csp": null
        },
        "windows": [
            {
                "label": "main",
                "title": "Clipboard History",
                "width": 800,
                "height": 600,
                "visible": true,
                "decorations" : false
            }
        ]
    }
}